{
    "version": 2,
    "functions": {
      "api/index.php": {
        "runtime": "vercel-php@0.7.2"
      }
    },
    "routes": [
      {
        "src": "/assets/(.*)",
        "dest": "/assets/$1"
      },
      {
        "src": "/uploads/(.*)",
        "dest": "/uploads/$1"
      },
      {
        "src": "/",
        "dest": "api/index.php"
      },
      {
        "src": "/(.*\\.php)",
        "dest": "api/index.php"
      },
      {
        "src": "/(.*)",
        "dest": "api/index.php"
      }
    ]
  }